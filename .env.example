# OpenClaw Gateway — required for live agents
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_TOKEN=

# SQLite database path (auto-created on first db:push)
DATABASE_URL=./data/office.db

# Dashboard auth (set by SKILL.md auto-installer, or set manually)
OFFICE_USER=office
OFFICE_PASSWORD=change_me

# Optional: USD estimates when JSONL usage.cost = 0 (USD per 1M tokens)
# OPENCLAW_COST_INPUT_PER_M=3
# OPENCLAW_COST_OUTPUT_PER_M=15
# OPENCLAW_COST_CACHE_READ_PER_M=0.3
# OPENCLAW_COST_CACHE_WRITE_PER_M=3.75

# Optional: OpenClaw agents dir for /api/openclaw/cost-report (session *.jsonl)
# Default: ~/.openclaw/agents (relative to process user HOME)
# OPENCLAW_AGENTS_DIR=/path/to/.openclaw/agents

# Optional: OpenClaw data root; if set, agents dir is OPENCLAW_HOME/agents
# OPENCLAW_HOME=/path/to/.openclaw

# Optional: NanoBananaPro USD per image generation (default 0.05)
# NANO_BANANA_PRO_USD_PER_GEN=0.05
