# OpenClaw Gateway — required to show live agents
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_TOKEN=your_gateway_token_here

# SQLite database path (auto-created on first db:push)
DATABASE_URL=./data/office.db

# Dashboard auth (set by SKILL.md auto-installer, or set manually)
OFFICE_USER=office
OFFICE_PASSWORD=change_me
